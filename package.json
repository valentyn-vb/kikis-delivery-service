{
  "name": "kikis-delivery-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:up && next dev",
    "build": "next build",
    "start": "next start",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d --wait"
  },
  "dependencies": {
    "next": "16.2.9",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "typescript": "^5"
  }
}
